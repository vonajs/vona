{
  "name": "vona-module-start-test",
  "type": "module",
  "version": "5.0.0",
  "title": "start-test",
  "vonaModule": {
    "fileVersion": 1,
    "dependencies": {
      "a-vona": "5.0.0"
    }
  },
  "exports": {
    ".": {
      "types": [
        "./src/index.ts",
        "./dist/index.d.ts"
      ],
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "description": "",
  "keywords": ["Vona Module"],
  "author": "",
  "files": [
    "assets",
    "dist"
  ],
  "scripts": {
    "clean": "rimraf dist tsconfig.build.tsbuildinfo",
    "tsc:publish": "npm run clean && vona :bin:buildModule && tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run tsc:publish",
    "prepack": "clean-package",
    "postpack": "clean-package restore && npm run clean",
    "version": "node ../../../../../scripts/version-cabloy-start.ts"
  },
  "clean-package": {
    "indent": 2,
    "remove": [
      "clean-package",
      "devDependencies",
      "exports.\\..import"
    ]
  },
  "dependencies": {
    "@faker-js/faker": "^10.0.0"
  },
  "devDependencies": {
    "clean-package": "^2.2.0",
    "rimraf": "^6.0.1"
  }
}
