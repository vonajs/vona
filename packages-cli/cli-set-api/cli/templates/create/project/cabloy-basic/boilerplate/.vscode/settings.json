{
  "editor.tabSize": 2,
  // "editor.formatOnSave": true,
  "editor.formatOnSave": false,
  "editor.formatOnPaste": false,
  "files.eol": "\n",
  // typescript
  "ts.disableAutomaticTypeAcquisition": false,
  "ts.format.enable": true,
  "ts.implementationsCodeLens.enabled": true,
  "ts.tsserver.useSyntaxServer": "auto",
  "ts.validate.enable": true,
  "ts.suggest.autoImports": true,
  "ts.suggest.includeCompletionsForImportStatements": true,
  "ts.preferences.importModuleSpecifier": "shortest",
  "ts.preferences.importModuleSpecifierEnding": "js",
  "ts.preferences.includePackageJsonAutoImports": "on",
  // eslint
  "editor.codeActionsOnSave": {
    "source.fixAll.oxc": "always"
  },
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "vue"
  ],
  // associations
  "files.associations": {
    "*.js.ejs": "javascript",
    "*.css.ejs": "css",
    "*.less.ejs": "less",
    "*.code-snippets": "text",
    "docker-compose-dockerfile-app": "dockerfile"
  },
  // search
  "search.exclude": {
    "/.vscode/**": true,
    "/coverage/**": true,
    "/docs/**": true,
    "**/dist/**": true,
    "/src/backend/app/**": true,
    "/src/backend/logs/**": true,
    "/src/backend/run/**": true,
    "**/node_modules": true
  },
  "search.useIgnoreFiles": false,
  "hide-my-secrets.hideSecrets": false
}
