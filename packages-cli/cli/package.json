{
  "name": "vona-cli",
  "version": "1.1.39",
  "gitHead": "a79189b882c17af5911573896a781bbb0046d37d",
  "description": "vona cli",
  "keywords": [
    "framework",
    "vona"
  ],
  "license": "MIT",
  "author": "zhennann",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": [
        "./src/index.ts",
        "./dist/index.d.ts"
      ],
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./*": "./*"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "tsc:publish": "npm run clean && tsc",
    "prepublishOnly": "npm run tsc:publish",
    "prepack": "clean-package",
    "postpack": "clean-package restore"
  },
  "dependencies": {
    "@cabloy/cli": "workspace:^",
    "@cabloy/process-helper": "workspace:^",
    "fs-extra": "^11.3.4",
    "semver": "^7.7.4",
    "vona-cli-set-api": "workspace:^"
  },
  "devDependencies": {
    "clean-package": "^2.2.0",
    "rimraf": "^6.1.3"
  },
  "clean-package": {
    "indent": 2,
    "replace": {
      "bin.vona": "dist/bin/vona.js",
      "exports.\\..types": "./dist/index.d.ts"
    },
    "remove": [
      "clean-package",
      "devDependencies",
      "exports.\\..import"
    ]
  }
}
