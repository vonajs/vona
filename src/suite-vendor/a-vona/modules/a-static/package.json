{
  "name": "vona-module-a-static",
  "version": "5.1.1",
  "description": "",
  "keywords": [
    "Vona Module"
  ],
  "author": "",
  "files": [
    "assets",
    "cli",
    "dist",
    "src"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": [
        "./src/index.ts",
        "./dist/index.d.ts"
      ],
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "rimraf dist tsconfig.build.tsbuildinfo",
    "tsc:publish": "npm run clean && vona :bin:buildModule --sourcemap && tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run tsc:publish",
    "prepack": "clean-package",
    "postpack": "clean-package restore && npm run clean"
  },
  "dependencies": {
    "@cabloy/koa-static-cache": "^6.0.1",
    "koa-range": "^0.3.0",
    "ylru": "^2.0.0"
  },
  "devDependencies": {
    "clean-package": "^2.2.0",
    "rimraf": "^6.0.1"
  },
  "clean-package": {
    "indent": 2,
    "remove": [
      "clean-package",
      "exports.\\..import"
    ]
  },
  "title": "a-static",
  "vonaModule": {
    "dependencies": {},
    "metas": {
      "static": {
        "scopeResource": true,
        "boilerplate": "static/boilerplate"
      },
      "asset": {
        "scopeResource": true,
        "boilerplate": "asset/boilerplate"
      }
    }
  },
  "gitHead": "991189da4443b789fcf77872990b901ccf43bccb"
}
