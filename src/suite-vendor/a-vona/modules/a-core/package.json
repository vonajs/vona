{
  "name": "vona-module-a-core",
  "version": "5.1.8",
  "gitHead": "a79189b882c17af5911573896a781bbb0046d37d",
  "description": "",
  "keywords": [
    "Vona Module"
  ],
  "author": "",
  "files": [
    "assets",
    "dist",
    "src"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": [
        "./src/index.ts",
        "./dist/index.d.ts"
      ],
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "rimraf dist tsconfig.build.tsbuildinfo",
    "tsc:publish": "npm run clean && vona :bin:buildModule --sourcemap && tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run tsc:publish",
    "prepack": "clean-package",
    "postpack": "clean-package restore && npm run clean"
  },
  "dependencies": {
    "@babel/core": "^7.29.0",
    "@babel/traverse": "^7.29.0",
    "@cabloy/deps": "workspace:^",
    "@cabloy/json5": "workspace:^",
    "@cabloy/module-info": "^2.0.0",
    "@cabloy/type-fest": "^5.3.1",
    "@cabloy/utils": "workspace:^",
    "@cabloy/word-utils": "^2.1.8",
    "bignumber.js": "^9.3.1",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "fs-extra": "^11.3.4",
    "koa-override": "^4.0.0",
    "luxon": "^3.7.2",
    "mutate-on-copy": "^1.1.8",
    "react": "^19.2.5",
    "retry": "^0.13.1",
    "uuid": "^11.1.0",
    "vona-shared": "workspace:^",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@cabloy/cli": "workspace:^",
    "@swc/core": "^1.15.26",
    "@swc/helpers": "^0.5.21",
    "@types/babel__core": "^7.20.5",
    "@types/babel__traverse": "^7.28.0",
    "@types/koa": "^2.15.0",
    "@types/luxon": "^3.7.1",
    "@types/node": "^22.19.17",
    "@types/react": "npm:@cabloy/types-react@^19.2.13",
    "@types/retry": "^0.12.5",
    "clean-package": "^2.2.0",
    "cross-env": "^7.0.3",
    "gogocode": "^1.0.55",
    "rimraf": "^6.1.3",
    "ts-node-maintained": "^10.9.6",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vona-mock": "workspace:^",
    "why-is-node-running": "^3.2.2"
  },
  "clean-package": {
    "indent": 2,
    "remove": [
      "clean-package",
      "exports.\\..import"
    ]
  },
  "title": "a-core",
  "vonaModule": {
    "dependencies": {},
    "globalDependencies": {
      "@babel/core": true,
      "@babel/traverse": true,
      "@cabloy/deps": true,
      "@cabloy/json5": true,
      "@cabloy/module-info": true,
      "@cabloy/type-fest": true,
      "@cabloy/utils": true,
      "@cabloy/word-utils": true,
      "bignumber.js": true,
      "boxen": true,
      "chalk": true,
      "cli-table3": true,
      "fs-extra": true,
      "luxon": true,
      "mutate-on-copy": true,
      "react": true,
      "retry": true,
      "uuid": true,
      "vona-shared": true,
      "winston": true
    },
    "globalDependenciesDev": {
      "@cabloy/cli": true,
      "@swc/core": true,
      "@swc/helpers": true,
      "@types/babel__core": true,
      "@types/babel__traverse": true,
      "@types/koa": true,
      "@types/luxon": true,
      "@types/node": true,
      "@types/react": true,
      "@types/retry": true,
      "cross-env": true,
      "gogocode": true,
      "ts-node-maintained": true,
      "tslib": true,
      "typescript": true,
      "vona-mock": true,
      "why-is-node-running": true
    }
  }
}
