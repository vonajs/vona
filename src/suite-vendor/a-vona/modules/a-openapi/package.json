{
  "name": "vona-module-a-openapi",
  "version": "5.1.3",
  "gitHead": "a79189b882c17af5911573896a781bbb0046d37d",
  "description": "",
  "keywords": [
    "Vona Module"
  ],
  "author": "",
  "files": [
    "assets",
    "dist",
    "src"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": [
        "./src/index.ts",
        "./dist/index.d.ts"
      ],
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "rimraf dist tsconfig.build.tsbuildinfo",
    "tsc:publish": "npm run clean && vona :bin:buildModule --sourcemap && tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run tsc:publish",
    "prepack": "clean-package",
    "postpack": "clean-package restore && npm run clean"
  },
  "dependencies": {
    "@cabloy/zod-openapi": "workspace:^",
    "@cabloy/zod-query": "workspace:^",
    "@cabloy/zod-to-openapi": "^8.1.5",
    "@zhennann/currency": "^2.0.4",
    "openapi3-ts": "^4.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "clean-package": "^2.2.0",
    "rimraf": "^6.1.3"
  },
  "clean-package": {
    "indent": 2,
    "remove": [
      "clean-package",
      "exports.\\..import"
    ]
  },
  "title": "a-openapi",
  "vonaModule": {
    "capabilities": {
      "preload": true
    },
    "dependencies": {
      "a-openapiutils": "5.0.0"
    },
    "globalDependencies": {
      "@cabloy/zod-openapi": true,
      "@cabloy/zod-to-openapi": true,
      "openapi3-ts": true,
      "zod": true
    }
  }
}
