{
  "name": "vona-module-a-cache",
  "version": "5.1.2",
  "description": "",
  "keywords": [
    "Vona Module"
  ],
  "author": "",
  "files": [
    "assets",
    "cli",
    "dist",
    "src"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": [
        "./src/index.ts",
        "./dist/index.d.ts"
      ],
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "rimraf dist tsconfig.build.tsbuildinfo",
    "tsc:publish": "npm run clean && vona :bin:buildModule --sourcemap && tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run tsc:publish",
    "prepack": "clean-package",
    "postpack": "clean-package restore && npm run clean"
  },
  "dependencies": {
    "lru-cache": "^11.0.2"
  },
  "devDependencies": {
    "clean-package": "^2.2.0",
    "rimraf": "^6.0.1"
  },
  "clean-package": {
    "indent": 2,
    "remove": [
      "clean-package",
      "exports.\\..import"
    ]
  },
  "title": "a-cache",
  "vonaModule": {
    "dependencies": {},
    "onions": {
      "cacheMem": {
        "optionsGlobalInterfaceName": "IDecoratorCacheMemOptions",
        "optionsGlobalInterfaceFrom": "vona-module-a-cache",
        "scopeResource": true,
        "boilerplate": "cacheMem/boilerplate"
      },
      "cacheRedis": {
        "optionsGlobalInterfaceName": "IDecoratorCacheRedisOptions",
        "optionsGlobalInterfaceFrom": "vona-module-a-cache",
        "scopeResource": true,
        "boilerplate": "cacheRedis/boilerplate"
      }
    }
  },
  "gitHead": "a79189b882c17af5911573896a781bbb0046d37d"
}
