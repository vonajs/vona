{
  "name": "vona-module-a-ssr",
  "version": "5.1.1",
  "description": "",
  "keywords": [
    "Vona Module"
  ],
  "author": "",
  "files": [
    "assets",
    "cli",
    "dist",
    "src"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": [
        "./src/index.ts",
        "./dist/index.d.ts"
      ],
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "rimraf dist tsconfig.build.tsbuildinfo",
    "tsc:publish": "npm run clean && vona :bin:buildModule --sourcemap && tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run tsc:publish",
    "prepack": "clean-package",
    "postpack": "clean-package restore && npm run clean"
  },
  "dependencies": {
    "http-proxy": "^1.18.1",
    "vona-module-a-socket": "^5.1.1"
  },
  "devDependencies": {
    "@types/http-proxy": "^1.17.16",
    "clean-package": "^2.2.0",
    "rimraf": "^6.0.1"
  },
  "clean-package": {
    "indent": 2,
    "remove": [
      "clean-package",
      "exports.\\..import"
    ]
  },
  "title": "a-ssr",
  "vonaModule": {
    "dependencies": {
      "a-vona": "5.0.0",
      "a-socket": "5.0.0"
    },
    "onions": {
      "ssrSite": {
        "optionsGlobalInterfaceName": "IDecoratorSsrSiteOptions",
        "optionsGlobalInterfaceFrom": "vona-module-a-ssr",
        "boilerplate": "ssrSite/boilerplate"
      },
      "ssrMenu": {
        "optionsGlobalInterfaceName": "IDecoratorSsrMenuOptions",
        "optionsGlobalInterfaceFrom": "vona-module-a-ssr",
        "boilerplate": "ssrMenu/boilerplate"
      },
      "ssrMenuGroup": {
        "optionsGlobalInterfaceName": "IDecoratorSsrMenuGroupOptions",
        "optionsGlobalInterfaceFrom": "vona-module-a-ssr",
        "boilerplate": "ssrMenuGroup/boilerplate"
      }
    },
    "capabilities": {
      "monkey": true
    }
  },
  "gitHead": "991189da4443b789fcf77872990b901ccf43bccb"
}
