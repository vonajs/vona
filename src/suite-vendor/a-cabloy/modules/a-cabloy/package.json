{
  "name": "vona-module-a-cabloy",
  "version": "5.0.3",
  "description": "",
  "keywords": [
    "Vona Module"
  ],
  "author": "",
  "files": [
    "assets",
    "dist",
    "src"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": [
        "./src/index.ts",
        "./dist/index.d.ts"
      ],
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "rimraf dist tsconfig.build.tsbuildinfo",
    "tsc:publish": "npm run clean && vona :bin:buildModule --sourcemap && tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run tsc:publish",
    "prepack": "clean-package",
    "postpack": "clean-package restore && npm run clean"
  },
  "devDependencies": {
    "clean-package": "^2.2.0",
    "rimraf": "^6.0.1"
  },
  "clean-package": {
    "indent": 2,
    "remove": [
      "clean-package",
      "exports.\\..import"
    ]
  },
  "title": "a-cabloy",
  "vonaModule": {
    "dependencies": {
      "a-vona": "5.0.0",
      "a-datasharding": "5.0.0",
      "a-datasource": "5.0.0",
      "a-socket": "5.0.0",
      "a-ssr": "5.0.0",
      "a-ssrhmr": "5.0.0",
      "a-status": "5.0.0"
    }
  }
}
