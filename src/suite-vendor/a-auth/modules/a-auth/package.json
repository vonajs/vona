{
  "name": "vona-module-a-auth",
  "version": "5.0.53",
  "description": "",
  "keywords": [
    "Vona Module"
  ],
  "author": "",
  "files": [
    "assets",
    "cli",
    "dist",
    "src"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": [
        "./src/index.ts",
        "./dist/index.d.ts"
      ],
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "rimraf dist tsconfig.build.tsbuildinfo",
    "tsc:publish": "npm run clean && vona :bin:buildModule --sourcemap && tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run tsc:publish",
    "prepack": "clean-package",
    "postpack": "clean-package restore && npm run clean"
  },
  "dependencies": {
    "passport-oauth2": "^1.8.0"
  },
  "devDependencies": {
    "clean-package": "^2.2.0",
    "rimraf": "^6.0.1"
  },
  "clean-package": {
    "indent": 2,
    "remove": [
      "clean-package",
      "exports.\\..import"
    ]
  },
  "title": "a-auth",
  "vonaModule": {
    "fileVersion": 1,
    "dependencies": {
      "a-orm": "5.0.0"
    },
    "globalDependencies": {
      "passport-oauth2": true
    },
    "onions": {
      "authProvider": {
        "optionsGlobalInterfaceName": "IDecoratorAuthProviderOptions",
        "optionsGlobalInterfaceFrom": "vona-module-a-auth",
        "scopeResource": true,
        "boilerplate": "boilerplate"
      }
    }
  }
}
