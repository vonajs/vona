{
  "name": "@cabloy/dotenv",
  "version": "1.2.3",
  "gitHead": "a79189b882c17af5911573896a781bbb0046d37d",
  "description": "cabloy dotenv",
  "keywords": [
    "cabloy",
    "framework"
  ],
  "author": "zhennann",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": [
        "./src/index.ts",
        "./dist/index.d.ts"
      ],
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rimraf dist tsconfig.build.tsbuildinfo",
    "tsc:publish": "npm run clean && vona :bin:buildGeneral && tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run tsc:publish",
    "prepack": "clean-package",
    "postpack": "clean-package restore"
  },
  "dependencies": {
    "cascade-extend": "^2.2.3",
    "dotenv": "^16.4.5",
    "dotenv-expand": "^11.0.6",
    "globby": "^16.0.0"
  },
  "devDependencies": {
    "clean-package": "^2.2.0",
    "rimraf": "^6.0.1"
  },
  "clean-package": {
    "indent": 2,
    "remove": [
      "clean-package",
      "devDependencies",
      "exports.\\..import"
    ]
  }
}
