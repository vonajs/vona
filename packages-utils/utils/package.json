{
  "name": "@cabloy/utils",
  "version": "2.1.10",
  "gitHead": "a79189b882c17af5911573896a781bbb0046d37d",
  "description": "cabloy utils",
  "keywords": [
    "cabloy",
    "framework"
  ],
  "author": "zhennann",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": [
        "./src/index.ts",
        "./dist/index.d.ts"
      ],
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "tsc:publish": "npm run clean && vona :bin:buildGeneral && tsc",
    "prepublishOnly": "npm run tsc:publish",
    "prepack": "clean-package",
    "postpack": "clean-package restore"
  },
  "dependencies": {
    "@cabloy/module-info": "^2.0.0",
    "@cabloy/word-utils": "^2.1.8",
    "@marcbachmann/cel-js": "^7.6.0",
    "object-hash": "^3.0.0"
  },
  "devDependencies": {
    "clean-package": "^2.2.0",
    "rimraf": "^6.1.3"
  },
  "clean-package": {
    "indent": 2,
    "remove": [
      "clean-package",
      "devDependencies",
      "exports.\\..import"
    ]
  }
}
