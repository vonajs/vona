{
  "name": "vona-core",
  "version": "5.1.2",
  "gitHead": "991189da4443b789fcf77872990b901ccf43bccb",
  "description": "vona",
  "keywords": [
    "cabloy",
    "framework"
  ],
  "author": "zhennann",
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": [
        "./src/index.ts",
        "./dist/index.d.ts"
      ],
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "tsc:publish": "npm run clean && vona :bin:buildGeneral --sourcemap && tsc",
    "prepublishOnly": "npm run tsc:publish",
    "prepack": "clean-package",
    "postpack": "clean-package restore"
  },
  "dependencies": {
    "@cabloy/compose": "^2.1.2",
    "@cabloy/extend": "^3.2.2",
    "@cabloy/json5": "^1.1.2",
    "@cabloy/localeutil": "^2.1.2",
    "@cabloy/module-info": "^2.0.0",
    "@cabloy/module-info-pro": "^1.1.2",
    "@cabloy/type-fest": "^5.3.1",
    "@cabloy/utils": "^2.1.2",
    "@cabloy/word-utils": "^2.0.2",
    "@cabloy/zod-errors-custom": "^2.1.2",
    "@cabloy/zod-openapi": "^1.1.2",
    "@cabloy/zod-query": "^2.1.2",
    "@cabloy/zod-to-openapi": "^8.1.5",
    "@types/react": "^19.2.7",
    "chalk": "^5.3.0",
    "fs-extra": "^10.1.0",
    "koa": "^3.0.0",
    "react": "^19.2.3",
    "reflect-metadata": "^0.2.2",
    "retry": "^0.13.1",
    "triple-beam": "^1.4.1",
    "uuid": "^11.0.3",
    "winston": "^3.18.3",
    "winston-daily-rotate-file": "^5.0.0",
    "winston-transport": "^4.9.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/koa": "^2.15.0",
    "@types/retry": "^0.12.5",
    "clean-package": "^2.2.0",
    "rimraf": "^6.0.1"
  },
  "clean-package": {
    "indent": 2,
    "remove": [
      "clean-package",
      "devDependencies",
      "exports.\\..import"
    ]
  }
}
