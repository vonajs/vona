{
  "name": "vona-core",
  "version": "5.1.8",
  "gitHead": "a79189b882c17af5911573896a781bbb0046d37d",
  "description": "vona",
  "keywords": [
    "cabloy",
    "framework"
  ],
  "author": "zhennann",
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": [
        "./src/index.ts",
        "./dist/index.d.ts"
      ],
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "tsc:publish": "npm run clean && vona :bin:buildGeneral --sourcemap && tsc",
    "prepublishOnly": "npm run tsc:publish",
    "prepack": "clean-package",
    "postpack": "clean-package restore"
  },
  "dependencies": {
    "@cabloy/compose": "workspace:^",
    "@cabloy/extend": "workspace:^",
    "@cabloy/json5": "workspace:^",
    "@cabloy/localeutil": "workspace:^",
    "@cabloy/module-info": "^2.0.0",
    "@cabloy/module-info-pro": "workspace:^",
    "@cabloy/type-fest": "^5.3.1",
    "@cabloy/utils": "workspace:^",
    "@cabloy/word-utils": "^2.1.8",
    "@cabloy/zod-errors-custom": "workspace:^",
    "@cabloy/zod-openapi": "workspace:^",
    "@cabloy/zod-query": "workspace:^",
    "@cabloy/zod-to-openapi": "^8.1.6",
    "@types/react": "npm:@cabloy/types-react@^19.2.13",
    "chalk": "^5.6.2",
    "fs-extra": "^10.1.0",
    "koa": "^3.2.0",
    "react": "^19.2.5",
    "reflect-metadata": "^0.2.2",
    "retry": "^0.13.1",
    "triple-beam": "^1.4.1",
    "uuid": "^11.1.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "winston-transport": "^4.9.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/koa": "^2.15.0",
    "@types/retry": "^0.12.5",
    "clean-package": "^2.2.0",
    "rimraf": "^6.1.3"
  },
  "clean-package": {
    "indent": 2,
    "remove": [
      "clean-package",
      "devDependencies",
      "exports.\\..import"
    ]
  }
}
